# Database
DATABASE_URL="postgresql://user:password@localhost:5432/swasthya_kosh"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRE="15m"
JWT_REFRESH_EXPIRE="7d"

# API Server
NODE_ENV="development"
PORT=3000
CLIENT_URL="http://localhost:5173"

# Claude AI
CLAUDE_API_KEY="sk-ant-..."

# Redis (optional, for caching/sessions)
REDIS_URL="redis://localhost:6379"

# Encryption (for sensitive financial data)
ENCRYPTION_KEY="your-32-char-hex-encryption-key"

# Email Service Configuration
# For Development: Use Mailhog (runs on localhost:1025 by default)
# For Production: Use real SMTP service (Gmail, SendGrid, Mailgun, etc.)

EMAIL_HOST="localhost"
EMAIL_PORT=1025
EMAIL_SECURE="false"
EMAIL_FROM="noreply@svasthya-kosh.app"
EMAIL_REPLY_TO="support@svasthya-kosh.app"

# Email Authentication (optional for Mailhog, required for production services)
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASSWORD="your-app-password"

# Enable Email Features
ENABLE_EMAIL_SCHEDULER="true"
ENABLE_BUDGET_ALERTS="true"
ENABLE_GOAL_NOTIFICATIONS="true"

# Production Email Examples:
# Gmail SMTP:
#   EMAIL_HOST="smtp.gmail.com"
#   EMAIL_PORT=587
#   EMAIL_SECURE="false"
#   EMAIL_USER="your-email@gmail.com"
#   EMAIL_PASSWORD="your-16-character-app-password"
#
# SendGrid SMTP:
#   EMAIL_HOST="smtp.sendgrid.net"
#   EMAIL_PORT=587
#   EMAIL_SECURE="false"
#   EMAIL_USER="apikey"
#   EMAIL_PASSWORD="SG.xxxxxxxxxxxx..."
